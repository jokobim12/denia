// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Photo {
  id          String   @id @default(cuid())
  imageUrl    String
  title       String
  description String
  eventDate   DateTime
  createdAt   DateTime @default(now())
}

model Letter {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String   // e.g. 'sad', 'tired', 'happy', 'cheer'
  createdAt DateTime @default(now())
}

model Timeline {
  id          String   @id @default(cuid())
  title       String
  description String
  imageUrl    String?
  eventDate   DateTime
  createdAt   DateTime @default(now())
}

model Playlist {
  id        String   @id @default(cuid())
  title     String
  embedUrl  String
  createdAt DateTime @default(now())
}
